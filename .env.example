# ───── Server ─────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY_HOPS=1
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000

# Comma-separated browser origins allowed for CORS. Leave empty for server-to-server only.
CORS_ORIGINS=

# ───── Mongo ─────
DB_URL=mongodb+srv://USER:PASS@cluster.example.mongodb.net/?retryWrites=true&w=majority
DB_NAME=multipay_wrapper

# ───── Client API auth — comma-separated keys ─────
# Generate each with: openssl rand -hex 32
API_KEYS=

# HMAC secret for outgoing webhooks. openssl rand -hex 32
WEBHOOK_SECRET=

# ───── Master mnemonic for HD wallets ─────
# Generate ONCE with: npm run generate-mnemonic
# Then store both here AND in 1Password / a secrets manager. Never change.
MASTER_MNEMONIC=

# ───── BSC ─────
BSC_RPC_URL=https://example-bsc.quiknode.pro/YOUR_TOKEN/
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSC_CONFIRMATIONS=15

# ───── Tron ─────
TRON_HTTP_URL=https://example.tron-mainnet.quiknode.pro/YOUR_TOKEN/jsonrpc
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_CONFIRMATIONS=19
TRON_API_KEY=

# ───── Watcher ─────
WATCHER_INTERVAL_MS=5000
WATCHER_MAX_BACKOFF_MS=60000
DEFAULT_PAYMENT_EXPIRATION_MIN=30

# ───── Sweep (used by sweep.js cron only) ─────
BSC_MAIN_WALLET=0x...
TRON_MAIN_WALLET=T...
BSC_GAS_WALLET_PK=
TRON_GAS_WALLET_PK=
MIN_SWEEP_USDT=2
BNB_GAS_TOPUP=0.0008
TRX_GAS_TOPUP=15